# ── Data ─────────────────────────────────────────────────────────────────────
# Processed parquet files (136 MB, 4764 files) — ignored by default.
# For a private referee repo where redistribution is confirmed, add:
#   !data/clean/
# to a local .gitignore override, or remove this line and commit the folder.
data/clean/

# Raw exchange data — never commit
*.log
*.mitch
data/raw/

# Large intermediate outputs that may land in data/ during replication
data/drift_diffusion/
data/state/
data/tables/
data/figures/

# ── Local manuscript / journal submission copies ─────────────────────────────
paper/
journal/

# ── OS noise ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# Co-author data export (regenerated by code/05_forecast/export_event_panel.py)
data/data_export/
